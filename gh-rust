#!/bin/sh
set -e

# Derive command names from the executable name (e.g. gh-rust -> gh rust).
MYNAKE=$(basename "$0")
GH_COMMAND=$(basename "${0}" | tr '-' ' ')
TOP=$(dirname "${0}")
COMMAND="${1}"
CONTAINER_NAME="${MYNAKE}"

if [ $# -eq 0 ];then
  echo "Usage: ${GH_COMMAND} [command]"
  echo " ${GH_COMMAND} setup     # Build the Docker image"
  echo " ${GH_COMMAND} shell     # Start a Rust shell in the Docker container"
  echo " ${GH_COMMAND} code      # Open VS Code attached to a Rust container"
  exit
fi

if [ "${COMMAND}" = "setup" ]; then
  # Build/update the image used by shell/code commands.
  docker compose -f "${TOP}/docker-compose.yml" build
  exit 0
fi

if [ "${COMMAND}" = "shell" ]; then
  # Run an interactive one-off container bound to the current directory.
  shift
  GITCONFIG_VOLUME_ARGS=""
  if [ -f "${HOME}/.gitconfig" ]; then
    GITCONFIG_VOLUME_ARGS="--volume ${HOME}/.gitconfig:/tmp/host_gitconfig:ro"
  fi
  docker compose -f "${TOP}/docker-compose.yml" run \
    --env CARGO_HOME=/workdir/.cargo \
    --env HOST_UID="$(id -u)" \
    --env HOST_GID="$(id -g)" \
    --env HOST_USER="$(id -un)" \
    --env HOST_GROUP="$(id -gn)" \
    --volume .:/workdir \
    ${GITCONFIG_VOLUME_ARGS} \
    -q --name "${MYNAKE}" \
    --rm "${MYNAKE}" "$@"
  exit 0
fi

if [ "${COMMAND}" = "code" ]; then
  shift
  GITCONFIG_VOLUME_ARGS=""
  if [ -f "${HOME}/.gitconfig" ]; then
    GITCONFIG_VOLUME_ARGS="--volume ${HOME}/.gitconfig:/workdir/.gitconfig:ro"
  fi

  cleanup() {
    docker rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
  }

  trap cleanup EXIT INT TERM
  if docker ps -a --format '{{.Names}}' | grep -qx "${CONTAINER_NAME}"; then
    EXPECTED_DOCKER_USER="$(id -u):$(id -g)"
    CURRENT_DOCKER_USER=$(docker inspect "${CONTAINER_NAME}" --format '{{.Config.User}}')
    CURRENT_CARGO_HOME=$(docker inspect "${CONTAINER_NAME}" --format '{{range .Config.Env}}{{println .}}{{end}}' | awk -F= '/^CARGO_HOME=/{print $2; exit}')
    if [ "${CURRENT_DOCKER_USER}" != "${EXPECTED_DOCKER_USER}" ] || [ "${CURRENT_CARGO_HOME}" != "/workdir/.cargo" ]; then
      docker rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true
    fi
  fi

  if ! docker ps -a --format '{{.Names}}' | grep -qx "${CONTAINER_NAME}"; then
    docker compose -f "${TOP}/docker-compose.yml" run \
      --detach \
      --user "$(id -u):$(id -g)" \
      --env HOST_UID="$(id -u)" \
      --env HOST_GID="$(id -g)" \
      --env HOST_USER="$(id -un)" \
      --env HOST_GROUP="$(id -gn)" \
      --env HOME="/workdir" \
      --env CARGO_HOME="/workdir/.cargo" \
      --volume "${PWD}:/workdir" \
      ${GITCONFIG_VOLUME_ARGS} \
      --name "${CONTAINER_NAME}" \
      --rm "${MYNAKE}" tail -f /dev/null >/dev/null
  fi

  if ! docker ps --format '{{.Names}}' | grep -qx "${CONTAINER_NAME}"; then
    docker start "${CONTAINER_NAME}" >/dev/null
  fi

  CONTAINER_HEX=$(printf '%s' "${CONTAINER_NAME}" | xxd -p | tr -d '\n')
  FOLDER_URI="vscode-remote://attached-container+${CONTAINER_HEX}/workdir/"

  code --new-window --wait --folder-uri "${FOLDER_URI}"

  exit 0
fi
