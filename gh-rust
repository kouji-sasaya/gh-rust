#!/usr/bin/env bash
set -e

# This is the main entry point for the gh-rust extension
# It will compile and execute the Rust binary on-demand

# Get the directory where this script is located
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Change to the extension directory
cd "$script_dir"

# Check if we have the source code
if [ ! -f "Cargo.toml" ]; then
    echo "Error: Cargo.toml not found. This extension requires Rust source code." >&2
    exit 1
fi

# Check if cargo is available
if ! command -v cargo >/dev/null 2>&1; then
    echo "Error: cargo (Rust) is not installed. Please install Rust from https://rustup.rs/" >&2
    exit 1
fi

# Build and run the Rust binary
exec cargo run --release -- "$@"